{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/publish_copy",
  "title": "Publish Copy",
  "description": "Platform-specific publish copy produced by the Publish Copy Director stage.",
  "type": "object",
  "required": ["version", "platforms"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "platforms": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "bilibili": {
          "type": "object",
          "required": ["title", "description", "tags"],
          "properties": {
            "title": { "type": "string", "maxLength": 80, "minLength": 1 },
            "description": { "type": "string", "minLength": 1 },
            "tags": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "maxItems": 10
            },
            "cover_ref": { "type": "string", "description": "Path to the platform cover image in renders/" }
          },
          "additionalProperties": false
        },
        "xiaohongshu": {
          "type": "object",
          "required": ["title", "body", "hashtags"],
          "properties": {
            "title": { "type": "string", "maxLength": 20, "minLength": 1 },
            "body": { "type": "string", "minLength": 1 },
            "hashtags": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "maxItems": 8
            },
            "cover_ref": { "type": "string", "description": "Path to the platform cover image in renders/" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cover_ref": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}